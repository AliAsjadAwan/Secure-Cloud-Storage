# Example environment variables for Secure Cloud Storage
# Copy this file to .env and fill values. NEVER commit your real .env.

# Flask secret key
SECRET_KEY=replace-with-your-secret-key

# Fernet key for file encryption (base64 urlsafe)
FERNET_KEY=replace-with-your-fernet-key

# HMAC secret used to sign download tokens
DOWNLOAD_SECRET=replace-with-your-download-secret

# Database URL for production (Postgres)
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/secure_cloud_storage

# Cloudinary credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
